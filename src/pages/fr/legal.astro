  <section class="pt-32 pb-20 md:pt-44 md:pb-28 px-6">
    <div class="max-w-3xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-12 fade-in">Mentions légales</h1>

      <div class="space-y-10 text-zinc-400 leading-relaxed fade-in">
        <div>
          <h2 class="text-lg font-semibold text-white mb-3">Éditeur du site</h2>
          <p>
            <strong class="text-zinc-200">OVERRIDE</strong><br />
            Société par Actions Simplifiée (SAS)<br />
            SIREN : 953 122 868<br />
            SIRET : 953 122 868 00011<br />
            Code APE : 62.01Z — Programmation informatique<br />
            12 Rue de Porspol, 29660 Carantec, France
          </p>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-white mb-3">Directeur de la publication</h2>
          <p>Charles Polart, Président</p>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-white mb-3">Contact</h2>
