---
import Layout from '../../layouts/Layout.astro';
import { getTranslations } from '../../i18n/translations';

const lang = 'en';
const t = getTranslations(lang);
---

<Layout title={t.meta.contactTitle} description={t.meta.contactDescription} lang={lang}>
  <section class="pt-32 pb-20 md:pt-44 md:pb-28 px-6">
    <div class="max-w-2xl mx-auto text-center">
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-6 fade-in">{t.contact.title}</h1>
      <p class="text-lg text-zinc-400 mb-10 fade-in">{t.contact.text}</p>
      <a
        href={`mailto:${t.contact.email}`}
        class="inline-flex items-center gap-3 text-2xl md:text-3xl font-mono text-accent hover:text-accent-light transition-colors duration-200 fade-in"
      >
        <svg class="w-7 h-7 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
        </svg>
        {t.contact.email}
      </a>
    </div>
  </section>
</Layout>
