---
import Layout from '../../layouts/Layout.astro';
import { getTranslations } from '../../i18n/translations';

const lang = 'en';
const t = getTranslations(lang);
---

<Layout title={t.meta.servicesTitle} description={t.meta.servicesDescription} lang={lang}>
  <section class="pt-32 pb-20 md:pt-44 md:pb-28 px-6">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-6 fade-in">{t.services.title}</h1>
      <p class="text-lg text-zinc-400 max-w-2xl mb-16 fade-in">{t.services.intro}</p>

      <div class="space-y-12">
        {[t.services.web, t.services.desktop, t.services.mobile].map((service, i) => (
          <div class="p-8 rounded-xl border border-zinc-800/50 bg-surface-light/30 fade-in">
            <div class="flex items-center gap-4 mb-6">
              <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center">
                <span class="text-accent font-mono text-sm font-bold">
                  {['</>', '#_', '[ ]'][i]}
                </span>
              </div>
              <h2 class="text-xl font-bold">{service.title}</h2>
            </div>
            <ul class="grid sm:grid-cols-2 gap-3">
              {service.items.map((item) => (
                <li class="flex items-center gap-3 text-zinc-300">
                  <span class="w-1.5 h-1.5 rounded-full bg-accent shrink-0"></span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <div class="mt-16 p-8 rounded-xl border border-accent/20 bg-accent/5 fade-in">
        <h2 class="text-xl font-bold mb-6">{t.services.quality.title}</h2>
        <div class="grid sm:grid-cols-2 gap-3">
          {t.services.quality.items.map((item) => (
            <div class="flex items-center gap-3 text-zinc-300">
              <span class="w-1.5 h-1.5 rounded-full bg-accent shrink-0"></span>
              {item}
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 px-6 border-t border-zinc-800/50">
    <div class="max-w-2xl mx-auto text-center fade-in">
      <h2 class="text-2xl md:text-3xl font-bold mb-6">{t.ctaSection.title}</h2>
      <a href={`/${lang}/contact`} class="btn-primary">{t.nav.contact}</a>
    </div>
  </section>
</Layout>
