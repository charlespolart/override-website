---
import Layout from '../../layouts/Layout.astro';
import { getTranslations } from '../../i18n/translations';
import { localUrl } from '../../i18n/url';

const lang = 'en';
const t = getTranslations(lang);
---

<Layout title={t.meta.aboutTitle} description={t.meta.aboutDescription} lang={lang}>
  <section class="pt-32 pb-20 md:pt-44 md:pb-28 px-6">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-16 fade-in">{t.about.title}</h1>

      <div class="space-y-16">
        <div class="fade-in">
          <h2 class="text-xl font-bold mb-4">{t.about.presentation.title}</h2>
          <p class="text-zinc-400 text-lg leading-relaxed">{t.about.presentation.text}</p>
        </div>

        <div class="fade-in">
          <h2 class="text-xl font-bold mb-6">{t.about.positioning.title}</h2>
          <div class="grid sm:grid-cols-3 gap-6">
            {t.about.positioning.items.map((item) => (
              <div class="p-6 rounded-xl border border-zinc-800/50 bg-surface-light/30">
                <div class="w-1 h-6 bg-accent rounded-full mb-4"></div>
                <p class="font-medium">{item}</p>
              </div>
            ))}
          </div>
        </div>

        <div class="fade-in">
          <h2 class="text-xl font-bold mb-4">{t.about.vision.title}</h2>
          <p class="text-zinc-400 text-lg leading-relaxed">{t.about.vision.text}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 px-6 border-t border-zinc-800/50">
    <div class="max-w-2xl mx-auto text-center fade-in">
      <h2 class="text-2xl md:text-3xl font-bold mb-6">{t.ctaSection.title}</h2>
      <a href={localUrl('/contact', lang)} class="btn-primary">{t.nav.contact}</a>
    </div>
  </section>
</Layout>
