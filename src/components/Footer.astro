---
import { getTranslations } from '../i18n/translations';
import type { Lang } from '../i18n/translations';
import { localUrl } from '../i18n/url';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="border-t border-zinc-800/50 bg-surface">
  <div class="max-w-6xl mx-auto px-6 py-8 flex flex-col sm:flex-row items-center justify-between gap-4">
    <div class="flex items-center gap-6 text-sm text-zinc-500">
      <span>&copy; {year} OVERRIDE. {t.footer.rights}</span>
    </div>
    <div class="flex items-center gap-6 text-sm">
      <a href={localUrl('/legal', lang)} class="text-zinc-500 hover:text-white transition-colors duration-200">
        {t.footer.legal}
      </a>
      <a
        href="mailto:contact@overridedev.com"
        class="text-zinc-500 hover:text-white transition-colors duration-200"
      >
        contact@overridedev.com
      </a>
    </div>
  </div>
</footer>
